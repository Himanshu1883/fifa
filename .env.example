# Copy to `.env` / `.env.local` and fill in values.

# PostgreSQL (required for the app and Prisma CLI). Use a URL with a database name path, e.g. `...:5432/mydb`
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE_NAME?sslmode=require"

# Optional — full copy of all app tables + rows to Railway (see `npm run db:push:railway`).
# Keep DATABASE_URL as the machine that has your **full** dataset; paste Railway’s **public** URL here (not *.railway.internal).
# RAILWAY_DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/railway?sslmode=require"

# Optional — protect GET /api/resale-pref/next (round-robin resale pref ids). If unset, the route is open to anyone who can reach the host.
# Use Authorization: Bearer <value> or ?secret=<value>
# RESALE_PREF_ROTATION_SECRET=

# Undetectable local API integration (see `/settings`).
# By default, Undetectable runs its local API on port 25325.
UNDETECTABLE_API_BASE_URL="http://127.0.0.1:25325"

# Local BoxOffice WebSocket server for Chrome extension dev (see `/settings`).
# Starts a local HTTP+WebSocket server at http://127.0.0.1:${BOXOFFICE_WS_PORT} and ws://127.0.0.1:${BOXOFFICE_WS_PORT}/ws
BOXOFFICE_WS_PORT=3020
#
# Optional — show BoxOffice WS controls/URLs in production/preview deployments.
# Default: dev-only (NODE_ENV=development).
# BOXOFFICE_WS_SHOW_IN_PROD=1
#
# Optional — if set, requires:
# - WS auth: first client message { "type": "boxoffice-auth", "token": "..." } within 5s
# - HTTP auth: Authorization: Bearer <token> for POST /broadcast
# BOXOFFICE_WS_TOKEN=

# Optional — protect /api/undetectable/* routes (proxy wrappers around the local Undetectable API).
# If set, requires Authorization: Bearer <value> or ?secret=<value>
# UNDETECTABLE_API_SECRET=

# Session cookie signing (HS256 via `jose`). Must be at least 32 characters.
# Generate a value:
#   openssl rand -base64 32
AUTH_SECRET=

# Gmail OAuth (Google Cloud Console → OAuth 2.0 Client IDs).
# Redirect URI must be added in Google Cloud Console:
#   http(s)://<your-host>/api/gmail/oauth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
#
# Used to encrypt refresh tokens at rest in Postgres. Must be 32+ characters.
# Rotate carefully (existing encrypted tokens become unreadable).
GMAIL_OAUTH_TOKEN_SECRET=

# Local dev ONLY (NODE_ENV=development): if AUTH_SECRET is empty, allow a fixed insecure dev secret.
# Never set in production or preview.
# ALLOW_INSECURE_DEV_AUTH=1

# Skip session checks for "/" and "/events/*" in dev only (browse without logging in).
# Never set in production.
# DISABLE_AUTH_PROXY=1
