{
  "name": "eventdetail",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:3010": "DISABLE_AUTH_PROXY=1 next dev --port 3010 --hostname 0.0.0.0",
    "dev:stable": "npm run dev:3010",
    "ws:dev": "node --import tsx scripts/boxoffice-ws-server.ts",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc",
    "db:migrate": "prisma migrate deploy",
    "db:copy:railway": "node --import tsx scripts/copy-app-data-postgres.ts",
    "db:push:railway": "TRUNCATE_TARGET=1 node --import tsx scripts/copy-app-data-postgres.ts",
    "db:seed": "prisma db seed",
    "db:row-counts": "node --import tsx scripts/db-row-counts.ts",
    "sock:set-all-resale": "node --import tsx scripts/set-sock-available-all-resale.ts --yes",
    "sock:set-all-resale:dry": "node --import tsx scripts/set-sock-available-all-resale.ts --dry-run",
    "catalogue:extract": "node --import tsx scripts/extract-catalogue-categories.ts",
    "import:seat-listings-sample": "node --import tsx scripts/import-seat-listings-sample.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "jose": "^6.2.3",
    "next": "16.2.5",
    "pg": "^8.16.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "ws": "^8.20.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pg": "^8.15.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.5",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
