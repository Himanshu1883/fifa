// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String   @map("password_hash")
  googleSub    String?  @unique @map("google_sub")
  googleEmail  String?  @map("google_email")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  isAdmin      Boolean  @default(false) @map("is_admin")
  isApproved   Boolean  @default(false) @map("is_approved")
  approvedAt   DateTime? @map("approved_at")

  gmailAccounts GmailAccount[]
  loginAudits   UserLoginAudit[]

  @@map("users")
}

enum AuthMethod {
  PASSWORD
  GOOGLE
}

model UserLoginAudit {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  ip        String?   @db.VarChar(64)
  country   String?   @db.VarChar(16)
  region    String?   @db.VarChar(96)
  city      String?   @db.VarChar(128)
  userAgent String?   @map("user_agent") @db.Text
  method    AuthMethod

  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@map("user_login_audits")
}

enum CataloguePriceSource {
  PRIMARY_PREF
  RESELL_PREF
}

enum BuyingCriteriaRuleKind {
  QTY_UNDER_PRICE
  TOGETHER_UNDER_PRICE
}

enum SockAvailableKind {
  RESALE
  LAST_MINUTE
}

model Event {
  id            Int                      @id @default(autoincrement())
  matchLabel    String                   @map("match_label")
  sortOrder     Int                      @map("sort_order")
  name          String
  isImportant   Boolean                  @default(false) @map("is_important")
  /// Match stage / round (e.g. group phase); optional for backfill.
  stage         String?
  venue         String?
  country       String?
  prefId        String                   @map("pref_id")
  resalePrefId  String?                  @map("resale_pref_id")
  /// SeatsBrokers event id mapping (optional).
  sbEventId     String?                  @map("sb_event_id")
  /// Calendar date of the match (used for SB date_to_ship = event_date − 2 days).
  eventDate     DateTime?                @map("event_date")
  categories    EventCategory[]
  shopEventCategoryBlocks ShopEventCategoryBlock[]
  blockPrices   EventCategoryBlockPrice[]
  blockAvailability EventCategoryBlockAvailability[]
  seatListings  EventSeatListing[]
  blockSeatNow  EventBlockSeatNow[]
  sockAvailable SockAvailable[]
  buyingCriteria EventBuyingCriteria?
  buyingCriteriaRules EventBuyingCriteriaRule[]
  sockAvailableWebhookDiffLogs SockAvailableWebhookDiffLog[]
  sbAutoPushRegistration SbEventAutoPush?
  sbListingPushLogs      SbListingPushLog[]
  sbBulkPushJobs         SbBulkPushJob[]
  sbBulkDeleteJobs       SbBulkDeleteJob[]

  @@index([sortOrder])
  @@index([prefId])
  @@index([resalePrefId])
}

model EventBuyingCriteria {
  id           Int      @id @default(autoincrement())
  eventId      Int      @unique @map("event_id")
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  cat1         String?  @db.Text
  cat2         String?  @db.Text
  cat3         String?  @db.Text
  cat3FrontRow Boolean  @default(false) @map("cat3_front_row")
  cat4         String?  @db.Text

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([eventId])
  @@map("event_buying_criteria")
}

model EventBuyingCriteriaRule {
  id               Int                   @id @default(autoincrement())
  eventId           Int                   @map("event_id")
  event             Event                 @relation(fields: [eventId], references: [id], onDelete: Cascade)

  categoryNum       Int                   @map("category_num")
  kind              BuyingCriteriaRuleKind

  minQty            Int?                  @map("min_qty")
  togetherCount     Int?                  @map("together_count")
  maxPriceUsdCents  Int?                  @map("max_price_usd_cents")

  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")

  @@index([eventId])
  @@index([eventId, categoryNum])
  @@map("event_buying_criteria_rules")
}

/// One resale / map seat listing row (GeoJSON feature) per event.
model EventSeatListing {
  id                 Int      @id @default(autoincrement())
  eventId            Int      @map("event_id")
  event              Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  categoryBlockId    String   @map("category_block_id")
  categoryBlockName  String   @map("category_block_name")

  areaId             String   @map("area_id")
  areaName           String   @map("area_name")

  color              String

  rowLabel           String   @map("row_label")
  seatNumber         String   @map("seat_number")

  seatCategoryId     String   @map("seat_category_id")
  seatCategoryName   String   @map("seat_category_name")

  contingentId       String   @map("contingent_id")

  amount             Decimal  @map("amount") @db.Decimal(18, 4)
  resaleMovementId   String   @map("resale_movement_id")
  exclusive          Boolean

  propertiesId       String   @map("properties_id")

  geometryType       String   @map("geometry_type")
  rotation           Int
  coordX             Int      @map("coord_x")
  coordY             Int      @map("coord_y")

  mainId             String   @map("main_id")

  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@unique([eventId, resaleMovementId])
  @@index([eventId])
  @@index([eventId, categoryBlockId])
  @@index([seatCategoryId])
  @@map("event_seat_listings")
}

model EventCategoryBlockPrice {
  id                Int                  @id @default(autoincrement())
  eventId           Int                  @map("event_id")
  event             Event                @relation(fields: [eventId], references: [id], onDelete: Cascade)
  categoryId        String               @map("category_id")
  categoryBlockId   String               @map("category_block_id")
  minPrice          Decimal              @map("min_price") @db.Decimal(14, 4)
  maxPrice          Decimal              @map("max_price") @db.Decimal(14, 4)
  catalogueSource   CataloguePriceSource @map("catalogue_source")

  @@unique([eventId, categoryId, categoryBlockId, catalogueSource])
  @@index([eventId])
  @@map("event_category_block_prices")
}

model EventCategoryBlockAvailability {
  id                  Int      @id @default(autoincrement())
  eventId              Int      @map("event_id")
  event                Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  categoryId           String   @map("category_id")
  categoryBlockId      String   @map("category_block_id")
  availability         Int      @map("availability")
  availabilityResale   Int      @map("availability_resale")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@unique([eventId, categoryId, categoryBlockId])
  @@index([eventId])
  @@map("event_category_block_availability")
}

model EventBlockSeatNow {
  id                Int      @id @default(autoincrement())
  eventId            Int      @map("event_id")
  event              Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  categoryId         String   @map("category_id")
  categoryName       String   @map("category_name")
  blockId            String   @map("block_id")
  availability       Int      @map("availability")
  availabilityResale Int      @map("availability_resale")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@unique([eventId, categoryId, blockId])
  @@index([eventId])
  @@map("event_block_seat_now")
}

model EventCategory {
  id                  Int    @id @default(autoincrement())
  eventId             Int    @map("event_id")
  event               Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  categoryId          String @map("category_id")
  categoryName        String @map("category_name")
  categoryBlockName   String @map("category_block_name")
  categoryBlockId     String @map("category_block_id")

  @@unique([eventId, categoryId, categoryBlockId])
  @@index([eventId])
}

model ShopEventCategoryBlock {
  eventId            Int     @map("event_id")
  event              Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)

  categoryId         String  @map("category_id")
  categoryName       String  @map("category_name")

  categoryBlockId    String  @map("category_block_id")
  categoryBlockName  String  @map("category_block_name")

  categoryPrice      Decimal? @map("category_price") @db.Decimal(14, 4)
  blockPrice         Decimal? @map("block_price") @db.Decimal(14, 4)

  @@id([eventId, categoryId, categoryBlockId])
  @@index([eventId])
  @@map("shop_event_category")
}

/// Singleton row `id = 1`: round-robin cursor for `GET /api/resale-pref/next`.
model ResalePrefRotationState {
  id        Int @id
  nextIndex Int @default(0) @map("next_index")

  @@map("resale_pref_rotation_state")
}

/// Round-robin cursor for `GET /api/pref/next` scoped by match range (e.g. "match:1-11").
model PrefRotationState {
  scope     String @id @db.Text
  nextIndex Int    @default(0) @map("next_index")

  @@map("pref_rotation_state")
}

/// Singleton row `id = 1`: global ticket markup % for seat-offers-transformed API.
model MarkupSettings {
  id            Int   @id
  markupPercent Float @default(0) @map("markup_percent")

  @@map("markup_settings")
}

/// Singleton row `id = 1`: global auto-push to SeatsBrokers when inventory updates.
model SbAutoPushSettings {
  id         Int     @id
  enabled    Boolean @default(false)
  ticketType String  @default("4") @map("ticket_type") @db.VarChar(8)

  @@map("sb_auto_push_settings")
}

/// Singleton row `id = 1`: SB push quantity rules and scrape-delete behavior.
model SbPushRulesSettings {
  id                        Int      @id
  togetherRules             Json     @map("together_rules")
  singleRules               Json     @map("single_rules")
  autoDeleteOnScrapeRemoval Boolean  @default(true) @map("auto_delete_on_scrape_removal")
  updatedAt                 DateTime @updatedAt @map("updated_at")

  @@map("sb_push_rules_settings")
}

/// Singleton row `id = 1`: outbound notification webhooks (Discord, etc.).
model AppWebhookSettings {
  id                           Int       @id
  discordNewListingsWebhookUrl String?   @map("discord_new_listings_webhook_url") @db.Text
  discordShopWebhookUrl        String?   @map("discord_shop_webhook_url") @db.Text
  shopDiscordBaselineSentAt    DateTime? @map("shop_discord_baseline_sent_at")
  updatedAt                    DateTime  @updatedAt @map("updated_at")

  @@map("app_webhook_settings")
}

/// Outbound Discord notify history for SHOP marketplace polls.
model ShopDiscordNotifyLog {
  id           Int      @id @default(autoincrement())
  createdAt    DateTime @default(now()) @map("created_at")
  mode         String   @db.Text
  matchCount   Int      @default(0) @map("match_count")
  changedCount Int      @default(0) @map("changed_count")
  attempted    Boolean  @default(false)
  ok           Boolean  @default(false)
  status       Int?
  error        String?  @db.Text
  notifyRaw    Json?    @map("notify_raw")

  @@index([createdAt])
  @@map("shop_discord_notify_logs")
}

/// Events that have had at least one manual SB push — eligible for auto-push when global toggle is on.
model SbEventAutoPush {
  eventId        Int      @id @map("event_id")
  event          Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  firstPushedAt  DateTime @default(now()) @map("first_pushed_at")
  lastAutoPushAt DateTime? @map("last_auto_push_at")

  @@map("sb_event_auto_push")
}

enum SbListingPushTrigger {
  MANUAL
  AUTO
}

enum SbBulkPushJobStatus {
  RUNNING
  COMPLETE
  FAILED
  CANCELLED
}

enum SbBulkDeleteJobStatus {
  RUNNING
  COMPLETE
  FAILED
  CANCELLED
}

model SbListingPushLog {
  id                 Int                  @id @default(autoincrement())
  eventId            Int                  @map("event_id")
  event              Event                @relation(fields: [eventId], references: [id], onDelete: Cascade)
  matchId            String               @map("match_id")
  offerIndex         Int?                 @map("offer_index")
  listingFingerprint String               @map("listing_fingerprint")
  trigger            SbListingPushTrigger
  ok                 Boolean
  httpStatus         Int?                 @map("http_status")
  sbTicketId         String?              @map("sb_ticket_id")
  requestFields      Json                 @map("request_fields")
  requestSummary     Json                 @map("request_summary")
  responseBody       Json?                @map("response_body")
  errorMessage       String?              @map("error_message") @db.Text
  inventoryRemovedAt DateTime?            @map("inventory_removed_at")
  sbDeletedAt        DateTime?            @map("sb_deleted_at")
  sbDeleteHttpStatus Int?                 @map("sb_delete_http_status")
  sbDeleteError      String?              @map("sb_delete_error") @db.Text
  createdAt          DateTime             @default(now()) @map("created_at")

  @@index([eventId, createdAt(sort: Desc)])
  @@index([eventId, listingFingerprint])
  @@index([eventId, inventoryRemovedAt])
  @@map("sb_listing_push_logs")
}

model SbBulkPushJob {
  id           Int                  @id @default(autoincrement())
  eventId      Int                  @map("event_id")
  event        Event                @relation(fields: [eventId], references: [id], onDelete: Cascade)
  status       SbBulkPushJobStatus  @default(RUNNING)
  items        Json
  current      Int                  @default(0)
  total        Int
  succeeded    Int                  @default(0)
  failed       Int                  @default(0)
  lastError    String?              @map("last_error") @db.Text
  currentLabel       String?              @map("current_label")
  cancelRequestedAt  DateTime?            @map("cancel_requested_at")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")
  completedAt        DateTime?            @map("completed_at")

  @@index([eventId, status])
  @@index([eventId, createdAt(sort: Desc)])
  @@map("sb_bulk_push_jobs")
}

model SbBulkDeleteJob {
  id           Int                    @id @default(autoincrement())
  eventId      Int                    @map("event_id")
  event        Event                  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  status       SbBulkDeleteJobStatus  @default(RUNNING)
  items        Json
  current      Int                    @default(0)
  total        Int
  succeeded    Int                    @default(0)
  failed       Int                    @default(0)
  lastError    String?                @map("last_error") @db.Text
  currentLabel       String?                @map("current_label")
  cancelRequestedAt  DateTime?              @map("cancel_requested_at")
  createdAt          DateTime               @default(now()) @map("created_at")
  updatedAt          DateTime               @updatedAt @map("updated_at")
  completedAt        DateTime?              @map("completed_at")

  @@index([eventId, status])
  @@index([eventId, createdAt(sort: Desc)])
  @@map("sb_bulk_delete_jobs")
}

model SockAvailable {
  id               Int      @id @default(autoincrement())
  eventId           Int      @map("event_id")
  event             Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  areaId            String   @map("area_id")
  areaName          String   @map("area_name")
  blockId           String   @map("block_id")
  blockName         String   @map("block_name")
  contingentId      String   @map("contingent_id")
  seatId            String   @map("seatid")
  seatNumber        String   @map("seat_number")
  amount            Decimal? @map("amount") @db.Decimal(18, 4)
  resaleMovementId  String?  @map("resalemovementid")
  row               String   @map("row")
  categoryName      String   @map("categoryname")
  categoryId        String   @map("category_id")
  kind              SockAvailableKind @default(RESALE) @map("kind")

  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@unique([eventId, resaleMovementId, kind])
  @@index([eventId])
  @@index([eventId, kind])
  @@map("sock_available")
}

model SockAvailableWebhookDiffLog {
  id               Int              @id @default(autoincrement())
  createdAt         DateTime         @default(now()) @map("created_at")

  eventId           Int              @map("event_id")
  event             Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)

  kind              SockAvailableKind @map("kind")
  prefId            String           @map("pref_id") @db.Text

  newCount          Int              @map("new_count")
  changedCount      Int              @map("changed_count")
  priceChangedCount Int              @map("price_changed_count")

  /// Capped JSON payloads to keep log rows bounded.
  newSeatIds        Json?            @map("new_seat_ids")
  sample            Json?            @map("sample")

  /// Optional notification metadata (best-effort).
  notifyAttempted   Boolean?         @map("notify_attempted")
  notifyOk          Boolean?         @map("notify_ok")
  notifyProvider    String?          @map("notify_provider") @db.VarChar(64)
  notifyStatus      String?          @map("notify_status") @db.VarChar(64)
  notifyError       String?          @map("notify_error") @db.Text
  notifyRaw         Json?            @map("notify_raw")

  @@index([eventId, kind, createdAt])
  @@index([eventId, createdAt])
  @@map("sock_available_webhook_diff_logs")
}

model GmailAccount {
  id                    Int           @id @default(autoincrement())
  userId                Int           @map("user_id")
  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  email                 String        @map("email")
  googleSub             String        @map("google_sub")

  encryptedRefreshToken String        @map("encrypted_refresh_token") @db.Text
  tokenVersion          Int           @default(0) @map("token_version")

  messages              GmailMessage[]

  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  @@unique([userId, googleSub])
  @@unique([userId, email])
  @@index([userId])
  @@map("gmail_accounts")
}

model GmailMessage {
  id             Int          @id @default(autoincrement())
  gmailMessageId String       @unique @map("gmail_message_id")
  threadId       String?      @map("thread_id")

  gmailAccountId Int          @map("gmail_account_id")
  gmailAccount   GmailAccount @relation(fields: [gmailAccountId], references: [id], onDelete: Cascade)

  from           String?      @db.Text
  subject        String?      @db.Text
  date           DateTime?    @map("date")
  snippet        String?      @db.Text
  internalDateMs BigInt?      @map("internal_date_ms")
  rawHeaders     Json?        @map("raw_headers")

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@index([gmailAccountId])
  @@map("gmail_messages")
}

/// Live LMS marketplace data from vivalafifa (per match, upserted on poll).
model ShopMarketplaceEventRecord {
  matchNum        Int       @id @map("match_num")
  externalEventId String    @map("external_event_id")
  linkedEventId   Int?      @map("linked_event_id")
  eventName       String    @map("event_name")
  stage           String?   @db.Text
  venue           String?   @db.Text
  country         String?   @db.Text
  eventDate       DateTime? @map("event_date")
  marketData      Json      @map("market_data")
  lowestPrice     Int?      @map("lowest_price")
  highestPrice    Int?      @map("highest_price")
  averagePrice    Int?      @map("average_price")
  availableCount  Int       @default(0) @map("available_count")
  listingsCount   Int       @default(0) @map("listings_count")
  rawPayload                    Json      @map("raw_payload")
  scannedAt                     DateTime  @map("scanned_at")
  lastDiscordNotifyFingerprint  String?   @map("last_discord_notify_fingerprint") @db.Text
  updatedAt                     DateTime  @updatedAt @map("updated_at")

  @@index([linkedEventId])
  @@index([scannedAt])
  @@map("shop_marketplace_events")
}

/// Latest full API payload + scan timestamp (singleton row id = 1).
model ShopMarketplaceSyncMeta {
  id         Int      @id @default(1)
  scannedAt  DateTime @map("scanned_at")
  rawPayload Json     @map("raw_payload")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("shop_marketplace_sync_meta")
}
